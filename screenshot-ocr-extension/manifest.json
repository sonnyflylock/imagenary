{
  "manifest_version": 3,
  "name": "ScreenScribe — AI Text Extractor",
  "version": "1.0.0",
  "description": "Select any area of your screen and instantly extract text with AI. Free to use, no setup required. By Imagenary AI.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "scripting",
    "notifications",
    "contextMenus",
    "offscreen"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://www.imagenary.ai/*",
    "https://imagenary.ai/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/js/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [{
    "matches": ["https://www.imagenary.ai/ext-auth*", "https://imagenary.ai/ext-auth*"],
    "js": ["src/js/content-auth.js"],
    "run_at": "document_idle"
  }],
  "commands": {
    "capture-screenshot": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Alt+C"
      },
      "description": "Extract text from screenshot"
    }
  }
}
